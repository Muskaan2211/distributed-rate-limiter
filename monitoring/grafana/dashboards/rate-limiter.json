{
  "title": "Distributed Rate Limiter",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {"type": "stat", "title": "Allowed Requests", "gridPos": {"x":0,"y":0,"w":8,"h":5}, "targets": [{"expr": "sum(rate(rate_limiter_requests_allowed_total[1m]))"}]},
    {"type": "stat", "title": "Blocked Requests", "gridPos": {"x":8,"y":0,"w":8,"h":5}, "targets": [{"expr": "sum(rate(rate_limiter_requests_blocked_total[1m]))"}]},
    {"type": "stat", "title": "Redis Up", "gridPos": {"x":16,"y":0,"w":8,"h":5}, "targets": [{"expr": "rate_limiter_redis_up"}]},
    {"type": "timeseries", "title": "Latency p95", "gridPos": {"x":0,"y":5,"w":24,"h":8}, "targets": [{"expr": "histogram_quantile(0.95, sum(rate(rate_limiter_request_latency_seconds_bucket[5m])) by (le))"}]}
  ]
}
